# Puerto del API (por defecto 8080)
PORT=8080
# Escuchar en todas las interfaces (necesario para probar el API desde el móvil por IP LAN). Opcional: HOST=127.0.0.1 solo local
HOST=0.0.0.0
# Secreto para firmar JWT (cambiar en producción)
JWT_SECRET=your-super-secret-key-change-in-production
# Conexión a Supabase (PostgreSQL). En Supabase: Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxx.supabase.co:5432/postgres

# AWS S3 (subida de archivos con presigned URL). Ver docs/s3-presigned-uploads.md
# Debe coincidir con la región real del bucket (consulta en S3 > bucket > Propiedades).
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
