# HTTP server
PORT=8090
LOG_LEVEL=info

# Azure OpenAI (DeepSeek-V4-Flash via Azure v1 API)
# Endpoint MUST include the /openai/v1 suffix as shown
AZURE_OPENAI_ENDPOINT=https://leonardpostillos-2026-resource.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=DeepSeek-V4-Flash
# Leave empty for the v1 API surface (/openai/v1). Set to "preview" or a dated
# version only if you point AZURE_OPENAI_ENDPOINT at the legacy /openai path.
AZURE_OPENAI_API_VERSION=

# OpenAI API (solo embeddings; chat sigue en Azure/DeepSeek)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_EMBED_DIMS=1536

# PostgreSQL (Supabase, must have pgvector enabled)
DATABASE_URL=

# Internal auth token. NestJS must send this in X-Internal-Token header.
INTERNAL_API_TOKEN=

# S3 (same bucket the NestJS backend uses)
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Ingest tuning
INGEST_CHUNK_TOKENS=500
INGEST_CHUNK_OVERLAP=80
INGEST_MAX_FILE_MB=50
RAG_TOPK_DEFAULT=5

# Milvus (vectores curso/clase)
MILVUS_HOST=144.202.73.63
MILVUS_PORT=19530
MILVUS_COLLECTION=course_resource_chunks
MILVUS_EMBED_DIMS=1536

# Webhook NestJS tras ingest de recurso
BACKEND_RESOURCE_WEBHOOK_URL=http://localhost:8080/internal/resources/ingested
BACKEND_WEBHOOK_TOKEN=

# URL pública opcional para key_url (si vacío: https://{bucket}.s3.{region}.amazonaws.com/{key})
S3_PUBLIC_BASE_URL=
