{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "src/main.ts",
      "framework": "nestjs",
      "routePrefix": "/_/backend",
      "installCommand": "npm install",
      "buildCommand": "npm run build"
    }
  }
}